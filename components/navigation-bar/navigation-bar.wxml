<view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
  <view class="nav-content">
    <!-- 左侧：返回按钮 / 自定义slot -->
    <view class="nav-left">
      <block wx:if="{{back}}">
        <view class="nav-back" bindtap="onBack" hover-class="nav-back-hover">
          <text class="nav-back-icon">‹</text>
        </view>
      </block>
      <block wx:else>
        <slot name="left"></slot>
      </block>
    </view>

    <!-- 中间：标题 -->
    <view class="nav-center">
      <block wx:if="{{title}}">
        <text class="nav-title">{{title}}</text>
      </block>
      <block wx:else>
        <slot name="center"></slot>
      </block>
    </view>

    <!-- 右侧：占位 / 自定义slot -->
    <view class="nav-right">
      <slot name="right"></slot>
    </view>
  </view>
</view>

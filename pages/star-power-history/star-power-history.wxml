<view class="page">
  <navigation-bar title="星力明细" />

  <!-- 筛选标签 -->
  <view class="filter-bar">
    <view class="filter-item {{filter === 'all' ? 'active' : ''}}" data-filter="all" bindtap="onFilterChange">
      <text class="filter-text">全部</text>
    </view>
    <view class="filter-item {{filter === 'income' ? 'active' : ''}}" data-filter="income" bindtap="onFilterChange">
      <text class="filter-text">收入</text>
    </view>
    <view class="filter-item {{filter === 'expense' ? 'active' : ''}}" data-filter="expense" bindtap="onFilterChange">
      <text class="filter-text">支出</text>
    </view>
  </view>

  <scroll-view type="list" scroll-y class="list-area" enhanced show-scrollbar="{{false}}">
    <view wx:if="{{loading}}" class="loading-wrap">
      <view class="loading-dots">
        <view class="dot"></view>
        <view class="dot"></view>
        <view class="dot"></view>
      </view>
    </view>

    <block wx:if="{{!loading}}">
      <view wx:if="{{filteredTransactions.length === 0}}" class="empty">
        <text class="empty-icon">📊</text>
        <text class="empty-text">暂无{{filter === 'income' ? '收入' : filter === 'expense' ? '支出' : ''}}记录</text>
      </view>

      <view wx:else class="list">
        <view class="item" wx:for="{{filteredTransactions}}" wx:key="id">
          <view class="item-left">
            <view class="item-icon-wrap {{item.amount > 0 ? 'income' : 'expense'}}">
              <text class="item-icon">{{item.type === 'register' ? '🎁' : item.type === 'checkin' ? '📅' : item.type === 'ad' ? '📺' : item.type === 'conversation' ? '💬' : '⚙️'}}</text>
            </view>
            <view class="item-info">
              <text class="item-type">{{item.type === 'register' ? '注册赠送' : item.type === 'checkin' ? '每日签到' : item.type === 'ad' ? '广告奖励' : item.type === 'conversation' ? '对话消耗' : item.type === 'adjust' ? '手动调整' : item.type}}</text>
              <text class="item-remark" wx:if="{{item.remark}}">{{item.remark}}</text>
              <text class="item-time">{{item.createdAt}}</text>
            </view>
          </view>
          <view class="item-right">
            <text class="item-amount {{item.amount > 0 ? 'income' : 'expense'}}">
              {{item.amount > 0 ? '+' : ''}}{{item.amount}}
            </text>
            <text class="item-balance">余额 {{item.balanceAfter}}</text>
          </view>
        </view>

        <view wx:if="{{loadingMore}}" class="loading-more">
          <text class="loading-more-text">加载中...</text>
        </view>
        <view wx:if="{{!hasMore && filteredTransactions.length > 0}}" class="no-more">
          <text class="no-more-text">没有更多了</text>
        </view>

        <view class="bottom-spacer"></view>
      </view>
    </block>
  </scroll-view>
</view>

var labels = {
  register_bonus: '注册赠送',
  checkin: '每日签到',
  ad_reward: '广告奖励',
  chat_cost: '对话消耗',
  admin_adjust: '手动调整',
};

var icons = {
  register_bonus: '/assets/icons/user-add.svg',
  checkin: '/assets/icons/calendar.svg',
  ad_reward: '/assets/icons/classic-tv.svg',
  chat_cost: '/assets/icons/message.svg',
  admin_adjust: '/assets/icons/helmet2.svg',
};

function label(type) {
  return labels[type] || type;
}

function icon(type) {
  return icons[type] || '⚙️';
}

module.exports = {
  label: label,
  icon: icon,
};

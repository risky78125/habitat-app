<view class="page">
  <navigation-bar back="{{false}}">
    <view slot="center" class="header-center">
      <text class="header-title">探索智能体</text>
      <text class="header-subtitle">发现最适合你的AI伙伴</text>
    </view>
  </navigation-bar>

  <scroll-view
    class="scroll-area"
    type="custom"
    scroll-y
    show-scrollbar="{{false}}"
    bindscrolltolower="onScrollToLower"
    lower-threshold="200"
  >
    <view class="search-container">
      <view class="search-bar">
        <view class="search-icon-wrap">
          <image class="search-icon-img" src="/assets/icons/search.svg" mode="aspectFit" />
        </view>
        <input
          class="search-input"
          placeholder="搜索智能体..."
          placeholder-style="color: #A8ABBC; font-size: 28rpx;"
          value="{{searchQuery}}"
          bindinput="onSearchInput"
          bindconfirm="onSearchConfirm"
          confirm-type="search"
        />
        <view class="search-clear" wx:if="{{searchQuery}}" bindtap="onSearchClear">
          <text>✕</text>
        </view>
      </view>
    </view>

    <sticky-section>
      <sticky-header>
        <swiper
          class="category-swiper"
          indicator-type="worm"
          indicator-offset="{{[0,10]}}"
          indicator-dots="{{categoryPages.length > 1}}"
          indicator-color="rgba(91, 108, 255, 0.2)"
          indicator-active-color="#5B6CFF"
          duration="250"
        >
          <swiper-item wx:for="{{categoryPages}}" wx:key="page">
            <view class="category-row">
              <view
                wx:for="{{item}}"
                wx:key="key"
                class="category-tab {{selectedCategory === item.key ? 'active' : ''}}"
                data-category="{{item.key}}"
                bindtap="onCategoryTap"
              >{{item.label}}</view>
            </view>
          </swiper-item>
        </swiper>
      </sticky-header>

      <view class="results-bar">
        <text class="results-count">{{total}} 个智能体</text>
      </view>

      <view wx:if="{{loading}}" class="loading-wrap">
        <view class="dot"></view>
        <view class="dot"></view>
        <view class="dot"></view>
      </view>

      <view wx:elif="{{agents.length === 0}}" class="empty-state">
        <text class="empty-icon">🔍</text>
        <text class="empty-title">没有找到匹配结果</text>
        <text class="empty-desc">试试其他关键词</text>
      </view>

      <view wx:else class="agent-list">
        <view
          wx:for="{{agents}}"
          wx:key="id"
          class="agent-card"
          data-id="{{item.id}}"
          bindtap="onAgentTap"
        >
          <view class="card-avatar" style="background: {{item.cardGradient}}">
            <text class="card-avatar-text">{{item.displayIcon}}</text>
          </view>
          <view class="card-info">
            <text class="card-name">{{item.name}}</text>
            <text class="card-desc">{{item.description}}</text>
            <view class="card-meta">
              <text class="card-tag">{{item.displayCategory}}</text>
            </view>
          </view>
          <text class="card-arrow">›</text>
        </view>
        <view wx:if="{{hasMore}}" class="load-more">加载更多...</view>
        <view class="bottom-spacer"></view>
      </view>
    </sticky-section>
  </scroll-view>
</view>

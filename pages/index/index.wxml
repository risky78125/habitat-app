<view class="page">
  <!-- 完善个人信息弹窗 -->
  <profile-setup show="{{showProfileSetup}}" bind:done="onProfileSetupDone" />
  <view class="header-bg"></view>
  <scroll-view type="custom" scroll-y class="scroll-area" enhanced show-scrollbar="{{false}}">

    <view class="header" style="padding-top: {{statusBarHeight}}px;">
      <view class="header-left">
        <text class="greeting">{{greeting}}</text>
        <text class="username">你好，{{nickname}}</text>
      </view>
    </view>
    <!-- Loading -->
    <view wx:if="{{loading}}" class="loading-wrap">
      <view class="loading-dots">
        <view class="dot"></view>
        <view class="dot"></view>
        <view class="dot"></view>
      </view>
    </view>

    <block wx:if="{{!loading}}">
      <!-- Featured agent -->
      <view wx:if="{{featuredAgent}}" class="featured-card" bindtap="onFeaturedTap">
        <view class="featured-ambient featured-ambient-1"></view>
        <view class="featured-ambient featured-ambient-2"></view>
        <view class="featured-content">
          <view class="featured-top">
            <view class="featured-badge">
              <text class="featured-badge-text">🔥 今日精选</text>
            </view>
            <view class="featured-icon">
              <text class="featured-icon-text">{{featuredIcon}}</text>
            </view>
          </view>
          <view class="featured-info">
            <text class="featured-name">{{featuredAgent.name}}</text>
          </view>
          <view class="featured-bottom">
            <text class="featured-desc">{{featuredAgent.description}}</text>
            <view class="featured-cta">
              <text class="featured-cta-text">对话 ›</text>
            </view>
          </view>
        </view>
      </view>

      <!-- Quick categories -->
      <view class="section">
        <view class="section-header">
          <text class="section-title">快速开始</text>
        </view>
        <view class="quick-grid">
          <view wx:for="{{quickCategories}}" wx:key="key" class="quick-item" style="background: {{item.bg}}" data-category="{{item.key}}" bindtap="onCategoryTap">
            <text class="quick-icon">{{item.icon}}</text>
            <text class="quick-label" style="color: {{item.color}}">{{item.label}}</text>
          </view>
        </view>
      </view>

      <!-- Hot agents -->
      <view class="section" wx:if="{{hotAgents.length > 0}}">
        <view class="section-header">
          <text class="section-title">热门智能体</text>
          <text class="section-more" bindtap="onViewAllAgents">查看全部</text>
        </view>
        <view class="agent-grid">
          <view wx:for="{{hotAgents}}" wx:key="id" class="agent-grid-item" data-id="{{item.id}}" bindtap="onAgentTap">
            <view class="agent-grid-icon" style="background: {{item.chipGradient}}">
              <text class="agent-grid-emoji">{{item.displayIcon}}</text>
            </view>
            <text class="agent-grid-name">{{item.name}}</text>
          </view>
        </view>
      </view>
      <!-- Recent conversations (logged in only) -->
      <view class="section" wx:if="{{isLoggedIn && recentConversations.length > 0}}">
        <view class="section-header">
          <text class="section-title">最近对话</text>
        </view>
        <view class="conv-list">
          <view wx:for="{{recentConversations}}" wx:key="id" class="conv-item" data-id="{{item.id}}" data-agent-id="{{item.agentId}}" bindtap="onConversationTap">
            <view class="conv-icon">
              <text class="conv-icon-text">{{item.displayIcon}}</text>
            </view>
            <view class="conv-info">
              <view class="conv-header">
                <text class="conv-title">{{item.title}}</text>
                <text class="conv-time">{{item.displayTime}}</text>
              </view>
              <text class="conv-preview">{{item.messageCount}} 条消息</text>
            </view>
          </view>
        </view>
      </view>

      <!-- Daily tip -->
      <view class="section daily-wrap">
        <view class="daily-tip">
          <text class="daily-tip-icon">💡</text>
          <view class="daily-tip-content">
            <text class="daily-tip-label">今日灵感</text>
            <text class="daily-tip-text">用AI重新思考你的工作流程——不是替代你，而是放大你最好的那部分。</text>
          </view>
        </view>
      </view>

      <view class="bottom-spacer"></view>
    </block>
  </scroll-view>
</view>
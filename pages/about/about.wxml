<view class="page">
  <navigation-bar title="关于栖息地" />

  <scroll-view type="list" scroll-y class="content-area" enhanced show-scrollbar="{{false}}">
    <view class="hero">
      <view class="hero-bg"></view>
      <view class="hero-content">
        <text class="app-icon">🏠</text>
        <text class="app-name">栖息地</text>
        <text class="app-slogan">发现你的 AI 助手</text>
        <text class="app-version">v{{version}}</text>
      </view>
    </view>

    <view class="section">
      <text class="section-title">核心功能</text>
      <view class="feature-list">
        <view class="feature-item" wx:for="{{features}}" wx:key="title">
          <text class="feature-icon">{{item.icon}}</text>
          <view class="feature-info">
            <text class="feature-title">{{item.title}}</text>
            <text class="feature-desc">{{item.desc}}</text>
          </view>
        </view>
      </view>
    </view>

    <view class="section">
      <text class="section-title">更多</text>
      <view class="link-list">
        <view class="link-item" wx:for="{{links}}" wx:key="key" data-key="{{item.key}}" bindtap="onLinkTap">
          <view class="link-info">
            <text class="link-title">{{item.title}}</text>
            <text class="link-desc">{{item.desc}}</text>
          </view>
          <text class="link-arrow">›</text>
        </view>
      </view>
    </view>

    <view class="footer">
      <text class="footer-text">© 2026 Habitat Haven</text>
      <text class="footer-text">用心打造 AI 体验</text>
    </view>
  </scroll-view>
</view>

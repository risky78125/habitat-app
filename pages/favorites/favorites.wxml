<view class="page">
  <navigation-bar title="我的收藏" />
  <view wx:if="{{loading}}" class="loading-wrap">
    <view class="loading-dots">
      <view class="dot"></view>
      <view class="dot"></view>
      <view class="dot"></view>
    </view>
  </view>

  <block wx:if="{{!loading}}">
    <view wx:if="{{favorites.length === 0}}" class="empty">
      <text class="empty-icon">⭐</text>
      <text class="empty-text">还没有收藏的 Agent</text>
      <text class="empty-hint">在探索页面点击 Agent 卡片上的星标即可收藏</text>
    </view>

    <view wx:else class="list">
      <view class="agent-card" wx:for="{{favorites}}" wx:key="id">
        <view class="agent-main" data-id="{{item.id}}" bindtap="onAgentTap">
          <view class="agent-avatar">
            <image wx:if="{{item.avatarUrl}}" class="agent-avatar-img" src="{{item.avatarUrl}}" mode="aspectFill" />
            <text wx:else class="agent-avatar-text">{{item.icon || '🤖'}}</text>
          </view>
          <view class="agent-info">
            <text class="agent-name">{{item.name}}</text>
            <text class="agent-desc">{{item.description}}</text>
            <view class="agent-meta">
              <text class="agent-category" wx:if="{{item.category}}">{{item.category}}</text>
              <text class="agent-cost">⚡ {{item.starPowerCostPerRound || 1}} 星力/轮</text>
            </view>
          </view>
        </view>
        <view class="agent-actions">
          <view class="remove-btn" data-id="{{item.id}}" data-name="{{item.name}}" bindtap="onRemoveFavorite">
            <text class="remove-icon">✕</text>
          </view>
        </view>
      </view>

      <view wx:if="{{loadingMore}}" class="loading-more">
        <text class="loading-more-text">加载中...</text>
      </view>
      <view wx:if="{{!hasMore && favorites.length > 0}}" class="no-more">
        <text class="no-more-text">没有更多了</text>
      </view>
    </view>
  </block>
</view>
